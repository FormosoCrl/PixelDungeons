<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.CharacterCreateActivity">

    <!-- Título -->
    <TextView
        android:id="@+id/character_crate_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Creación de personaje"
        android:textSize="38sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.15"
        />
    <!-- introducir nombre de personaje -->
    <EditText
        android:id="@+id/name_input"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:hint="Introduce tu nomrbe de personaje"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/character_crate_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.15"
        />
    <!-- textview de selección de raza -->
    <TextView
        android:id="@+id/race_selection_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona tu raza"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/name_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        />
    <!--spinner de selección de raza -->
    <Spinner
        android:id="@+id/race_spiner"
        android:layout_width="350dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/race_selection_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <!-- textview de selección de clase -->
    <TextView
        android:id="@+id/class_selection_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona tu clase"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/race_spiner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        />
    <!--spinner de selección de clase -->
    <Spinner
        android:id="@+id/class_spiner"
        android:layout_width="350dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/class_selection_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <!-- boton de creación -->
    <Button
        android:id="@+id/create_character_button"
        android:layout_width="250dp"
        android:layout_height="80dp"
        android:text="Crear personaje"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/class_spiner"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.25"
        />
</androidx.constraintlayout.widget.ConstraintLayout>