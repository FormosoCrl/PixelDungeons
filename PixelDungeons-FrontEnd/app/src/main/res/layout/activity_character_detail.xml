<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.CharacterDetailActivity">

    <TextView
        android:id="@+id/detail_char_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre del Héroe"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/hp_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Puntos de Vida (HP)"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/detail_char_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/hp_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="20 / 20"
        android:textSize="24sp"
        android:textColor="#8BC34A"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/hp_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/str_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STR (Fuerza)"
        app:layout_constraintTop_toBottomOf="@id/hp_value"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/dex_label"
        app:layout_constraintHorizontal_chainStyle="spread"
        android:layout_marginTop="40dp" />

    <TextView
        android:id="@+id/str_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30"
        android:textSize="24sp"
        android:textColor="#F44336"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/str_label"
        app:layout_constraintStart_toStartOf="@id/str_label"
        app:layout_constraintEnd_toEndOf="@id/str_label" />

    <TextView
        android:id="@+id/dex_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DEX (Destreza)"
        app:layout_constraintTop_toBottomOf="@id/hp_value"
        app:layout_constraintStart_toEndOf="@id/str_label"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp" />

    <TextView
        android:id="@+id/dex_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10"
        android:textSize="24sp"
        android:textColor="#F44336"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/dex_label"
        app:layout_constraintStart_toStartOf="@id/dex_label"
        app:layout_constraintEnd_toEndOf="@id/dex_label" />

    <TextView
        android:id="@+id/defence_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DEF (Defensa)"
        app:layout_constraintTop_toBottomOf="@id/str_value"
        app:layout_constraintStart_toStartOf="@id/str_label"
        app:layout_constraintEnd_toEndOf="@+id/str_label"
        app:layout_constraintHorizontal_chainStyle="spread"
        android:layout_marginTop="30dp" />

    <TextView
        android:id="@+id/defence_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15"
        android:textSize="24sp"
        android:textColor="#F44336"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/defence_label"
        app:layout_constraintStart_toStartOf="@id/defence_label"
        app:layout_constraintEnd_toEndOf="@id/defence_label" />

    <TextView
        android:id="@+id/mana_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MANA"
        app:layout_constraintTop_toBottomOf="@id/dex_value"
        app:layout_constraintStart_toStartOf="@id/dex_label"
        app:layout_constraintEnd_toEndOf="@id/dex_label"
        android:layout_marginTop="30dp" />

    <TextView
        android:id="@+id/mana_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10"
        android:textSize="24sp"
        android:textColor="#F44336"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/mana_label"
        app:layout_constraintStart_toStartOf="@id/mana_label"
        app:layout_constraintEnd_toEndOf="@id/mana_label" />

    <Button
        android:id="@+id/map_button"
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:text="Mapa"
        app:layout_constraintBottom_toTopOf="@id/inventory_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/inventory_button"
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:text="Inventario"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="50dp" />

</androidx.constraintlayout.widget.ConstraintLayout>