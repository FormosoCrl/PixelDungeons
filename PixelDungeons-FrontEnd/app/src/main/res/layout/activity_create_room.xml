<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.CreateRoomActivity">

    <!-- Título -->
    <TextView
        android:id="@+id/titulo_portada"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PixelDungeons"
        android:textSize="38sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.15"
        />
    <!-- introducir nombre de sala -->
    <EditText
        android:id="@+id/name_input"
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        android:hint="Introduce el nombre de la sala"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/titulo_portada"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.15"
        />
    <!-- introducir contraseña -->
    <EditText
        android:id="@+id/password_input"
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        android:hint="Introduce contraseña de la sala (si tiene)"
        android:textSize="20sp"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/name_input"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.1"
        />
    <!-- boton de creación -->
    <Button
        android:id="@+id/create_button"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="Crear partida"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/password_input"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.1"
        />

</androidx.constraintlayout.widget.ConstraintLayout>